# Copy this file to ".env.local" and fill in your values, then rebuild.
# Both are baked into the static build at build time (NEXT_PUBLIC_ prefix).

# Google Analytics 4 Measurement ID — looks like "G-XXXXXXXXXX"
NEXT_PUBLIC_GA_ID=

# Google Search Console verification code — the value of the
# <meta name="google-site-verification" content="..."> tag
NEXT_PUBLIC_GOOGLE_SITE_VERIFICATION=
